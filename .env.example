# ====== CLIENT-SIDE PUBLIC VARIABLES ======
# Exposed to Next.js Client Components
NEXT_PUBLIC_APP_URL=https://www.trouvable.app
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_public_site_key

# ====== SERVER-SIDE SECRET VARIABLES ======
# NEVER prefix these with NEXT_PUBLIC_ to avoid leaking to frontend
# Accessed only inside Server Actions, Route Handlers, or SSR (page.jsx)

# Supabase Admin access (bypasses RLS - keep secret!)
SUPABASE_URL=https://[YOUR_PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Server-side Public Access (Strictly used for Read-Only SSR pages like Client profiles)
SUPABASE_ANON_KEY=eyJ...

# Cloudflare Turnstile Verification
TURNSTILE_SECRET_KEY=1x000...

# Resend API and Email config
RESEND_API_KEY=re_...
ADMIN_EMAIL=your_admin_inbox@trouvable.app
FROM_EMAIL=Trouvable <contact@trouvable.app>

# ====== CLERK AUTHENTICATION ======
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/espace
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/espace/apres-connexion
# Comma-separated - seuls ces courriels accedent a /admin/* (Trouvable OS). Gmail: points ignores.
# L'invitation "portail client" (/portal) est independante : elle ne doit PAS etre listee ici sauf si c'est aussi un admin.
CLERK_ADMIN_EMAIL=contactmarchadidi@gmail.com
# CSP (vercel.json) autorise deja *.clerk.accounts.dev et *.clerk.com.

# ====== LOCAL DEV ONLY BYPASS ======
# Ignored outside NODE_ENV=development. Keep disabled by default.
DEV_BYPASS_AUTH=0
DEV_BYPASS_CLOUDFLARE=0
DEV_BYPASS_ADMIN_EMAIL=dev-admin@localhost

# ====== AI PROVIDERS ======
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...

AI_PRIMARY_PROVIDER=groq
AI_FALLBACK_PROVIDER=gemini

GROQ_MODEL_AUDIT=llama-3.3-70b-versatile
GROQ_MODEL_QUERY=llama-3.3-70b-versatile
GROQ_MODEL_BENCHMARK_COMPOUND_MINI=llama-3.3-70b-versatile
GEMINI_MODEL_AUDIT=gemini-2.5-flash
GEMINI_MODEL_QUERY=gemini-2.5-flash
GEMINI_MODEL_BENCHMARK_FREE=gemini-2.5-flash
BENCHMARK_ENABLE_FREE_SANDBOX=1

MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL_QUERY=mistral-small-2603
MISTRAL_MODEL_AUDIT=mistral-small-2603
MISTRAL_MODEL_COMPARE=mistral-small-2603
MISTRAL_MODEL_BENCHMARK_COMPARE=mistral-small-2603

# ====== CONTINUOUS VISIBILITY ENGINE ======
# Shared secret used by Vercel Cron route handlers:
# send as `Authorization: Bearer <CRON_SECRET>` (or `x-cron-secret`).
CRON_SECRET=change_me_long_random_secret
CONTINUOUS_DAILY_FIRST_MODE=1

# Optional local/dev toggle for connector stubs.
# When set to 1, GA4/GSC adapters return explicit sample-mode datasets.
CONNECTOR_SAMPLE_MODE=0

# ====== GOOGLE CONNECTORS ======
# Server-side only. Required to connect Google Search Console / GA4 via OAuth.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# Optional dedicated HMAC secret for OAuth state. Defaults to GOOGLE_OAUTH_CLIENT_SECRET when omitted.
GOOGLE_OAUTH_STATE_SECRET=change_me_long_random_secret

# Optional Search Console service-account fallback.
GOOGLE_SC_CLIENT_EMAIL=service-account@[PROJECT].iam.gserviceaccount.com
GOOGLE_SC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ====== SITE AUDIT / CRAWLER SAFETY CEILINGS ======
AUDIT_MAX_PAGES=2000
AUDIT_MAX_FETCH_ATTEMPTS=4000
AUDIT_MAX_DURATION_MS=720000
AUDIT_SITEMAP_SEED_LIMIT=200
AUDIT_MAX_URLS_FROM_SITEMAP=200
AUDIT_MAX_SITEMAP_DOCS=4
AUDIT_LINK_EXTRACTION_DEPTH=80
AUDIT_RENDER_ATTEMPT_LIMIT=8
AUDIT_RENDER_FETCH_FAILURE_ATTEMPT_LIMIT=10
AUDIT_FULL_TIMEOUT_MS=280000
